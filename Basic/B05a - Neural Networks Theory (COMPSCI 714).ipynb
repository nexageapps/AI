    "---\n",
    "\n",
    "# Part 3: The Perceptron (Rosenblatt, 1958)\n",
    "\n",
    "## 3.1 Historical Context\n",
    "\n",
    "The **Perceptron** was invented by Frank Rosenblatt in 1958 and is considered the first artificial neural network algorithm.\n",
    "\n",
    "### Perceptron Definition\n",
    "\n",
    "A perceptron is a binary classifier using a **step activation function**:\n",
    "\n",
    "```\n",
    "y = step(wбөҖx + b)\n",
    "\n",
    "where step(z) = {\n",
    "    1  if z вүҘ 0\n",
    "    0  if z < 0\n",
    "}\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Implement Perceptron\n",
    "\n",
    "class Perceptron:\n",
    "    def __init__(self, n_features, learning_rate=0.01):\n",
    "        \"\"\"Initialize perceptron with random weights\"\"\"\n",
    "        self.w = np.zeros(n_features)\n",
    "        self.b = 0\n",
    "        self.lr = learning_rate\n",
    "        self.errors = []\n",
    "    \n",
    "    def step(self, z):\n",
    "        \"\"\"Step activation function\"\"\"\n",
    "        return np.where(z >= 0, 1, 0)\n",
    "    \n",
    "    def predict(self, X):\n",
    "        \"\"\"Make predictions\"\"\"\n",
    "        z = X @ self.w + self.b\n",
    "        return self.step(z)\n",
    "    \n",
    "    def train(self, X, y, epochs=100):\n",
    "        \"\"\"Train using perceptron learning rule\"\"\"\n",
    "        for epoch in range(epochs):\n",
    "            errors = 0\n",
    "            for xi, yi in zip(X, y):\n",
    "                # Predict\n",
    "                y_pred = self.predict(xi.reshape(1, -1))[0]\n",
    "                \n",
    "                # Update if wrong\n",
    "                error = yi - y_pred\n",
    "                if error != 0:\n",
    "                    self.w += self.lr * error * xi\n",
    "                    self.b += self.lr * error\n",
    "                    errors += 1\n",
    "            \n",
    "            self.errors.append(errors)\n",
    "            if errors == 0:\n",
    "                print(f\"Converged at epoch {epoch+1}\")\n",
    "                break\n",
    "\n",
    "print(\"Perceptron class implemented!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.2 Example: Linearly Separable Data (AND Gate)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# AND gate (linearly separable)\n",
    "X_and = np.array([[0, 0], [0, 1], [1, 0], [1, 1]])\n",
    "y_and = np.array([0, 0, 0, 1])\n",
    "\n",
    "print(\"AND Gate Truth Table:\")\n",
    "print(\"xвӮҒ  xвӮӮ  | y\")\n",
    "print(\"----|----\")\n",
    "for xi, yi in zip(X_and, y_and):\n",
    "    print(f\"{xi[0]}   {xi[1]}   | {yi}\")\n",
    "\n",
    "# Train perceptron\n",
    "perceptron_and = Perceptron(n_features=2, learning_rate=0.1)\n",
    "perceptron_and.train(X_and, y_and, epochs=100)\n",
    "\n",
    "# Test\n",
    "print(\"\\nPredictions:\")\n",
    "predictions = perceptron_and.predict(X_and)\n",
    "for xi, yi, pred in zip(X_and, y_and, predictions):\n",
    "    print(f\"Input: {xi}, True: {yi}, Predicted: {pred}, {'вң“' if yi == pred else 'вң—'}\")\n",
    "\n",
    "print(f\"\\nLearned weights: {perceptron_and.w}\")\n",
    "print(f\"Learned bias: {perceptron_and.b:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.3 The XOR Problem (Perceptron Limitation)\n",
    "\n",
    "The famous limitation: **Perceptron cannot solve XOR** because it's not linearly separable!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# XOR gate (NOT linearly separable)\n",
    "X_xor = np.array([[0, 0], [0, 1], [1, 0], [1, 1]])\n",
    "y_xor = np.array([0, 1, 1, 0])\n",
    "\n",
    "print(\"XOR Gate Truth Table:\")\n",
    "print(\"xвӮҒ  xвӮӮ  | y\")\n",
    "print(\"----|----\")\n",
    "for xi, yi in zip(X_xor, y_xor):\n",
    "    print(f\"{xi[0]}   {xi[1]}   | {yi}\")\n",
    "\n",
    "# Try to train perceptron (will fail!)\n",
    "perceptron_xor = Perceptron(n_features=2, learning_rate=0.1)\n",
    "perceptron_xor.train(X_xor, y_xor, epochs=100)\n",
    "\n",
    "# Test\n",
    "print(\"\\nPredictions:\")\n",
    "predictions = perceptron_xor.predict(X_xor)\n",
    "for xi, yi, pred in zip(X_xor, y_xor, predictions):\n",
    "    print(f\"Input: {xi}, True: {yi}, Predicted: {pred}, {'вң“' if yi == pred else 'вң—'}\")\n",
    "\n",
    "accuracy = np.mean(predictions == y_xor)\n",
    "print(f\"\\nAccuracy: {accuracy*100:.1f}%\")\n",
    "print(\"\\nвҡ пёҸ Perceptron CANNOT solve XOR! This is why we need MLPs.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.4 Visualizing Decision Boundaries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize AND and XOR problems\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Plot AND gate\n",
    "axes[0].scatter(X_and[y_and==0, 0], X_and[y_and==0, 1], \n",
    "                c='blue', s=200, marker='o', label='Class 0', edgecolors='black', linewidth=2)\n",
    "axes[0].scatter(X_and[y_and==1, 0], X_and[y_and==1, 1], \n",
    "                c='red', s=200, marker='s', label='Class 1', edgecolors='black', linewidth=2)\n",
    "\n",
    "# Draw decision boundary for AND\n",
    "if perceptron_and.w[1] != 0:\n",
    "    x_line = np.linspace(-0.5, 1.5, 100)\n",
    "    y_line = -(perceptron_and.w[0] * x_line + perceptron_and.b) / perceptron_and.w[1]\n",
    "    axes[0].plot(x_line, y_line, 'g--', linewidth=2, label='Decision Boundary')\n",
    "\n",
    "axes[0].set_xlim(-0.5, 1.5)\n",
    "axes[0].set_ylim(-0.5, 1.5)\n",
    "axes[0].set_xlabel('xвӮҒ', fontsize=12)\n",
    "axes[0].set_ylabel('xвӮӮ', fontsize=12)\n",
    "axes[0].set_title('AND Gate (Linearly Separable) вң“', fontsize=14, fontweight='bold')\n",
    "axes[0].legend(fontsize=10)\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "# Plot XOR gate\n",
    "axes[1].scatter(X_xor[y_xor==0, 0], X_xor[y_xor==0, 1], \n",
    "                c='blue', s=200, marker='o', label='Class 0', edgecolors='black', linewidth=2)\n",
    "axes[1].scatter(X_xor[y_xor==1, 0], X_xor[y_xor==1, 1], \n",
    "                c='red', s=200, marker='s', label='Class 1', edgecolors='black', linewidth=2)\n",
    "\n",
    "axes[1].set_xlim(-0.5, 1.5)\n",
    "axes[1].set_ylim(-0.5, 1.5)\n",
    "axes[1].set_xlabel('xвӮҒ', fontsize=12)\n",
    "axes[1].set_ylabel('xвӮӮ', fontsize=12)\n",
    "axes[1].set_title('XOR Gate (NOT Linearly Separable) вң—', fontsize=14, fontweight='bold')\n",
    "axes[1].legend(fontsize=10)\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "axes[1].text(0.5, -0.3, 'No single line can separate these classes!', \n",
    "             ha='center', fontsize=11, color='red', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
