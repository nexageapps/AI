    "# ============================================================================\n",
    "# CAPSTONE PROJECT 1: Intelligent Document Classifier\n",
    "# Complete worked example — run every cell!\n",
    "# ============================================================================\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.datasets import fetch_20newsgroups\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.metrics import classification_report, confusion_matrix, accuracy_score\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print('=' * 70)\n",
    "print('CAPSTONE PROJECT 1: Intelligent Document Classifier')\n",
    "print('=' * 70)\n",
    "print('\\nThis project demonstrates the FULL ML pipeline:')\n",
    "print('  1. Data Collection & Exploration')\n",
    "print('  2. Preprocessing & Feature Engineering')\n",
    "print('  3. Model Training (Baseline + Advanced)')\n",
    "print('  4. Evaluation & Error Analysis')\n",
    "print('  5. Model Comparison & Selection')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 1: Data Collection & Exploration\n",
    "\n",
    "We use the **20 Newsgroups** dataset — a classic NLP benchmark with ~18,000 documents across 20 categories. We select 5 categories to keep it manageable."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Select 5 diverse categories\n",
    "CATEGORIES = [\n",
    "    'sci.space',           # Science\n",
    "    'rec.sport.baseball',  # Sports\n",
    "    'comp.graphics',       # Technology\n",
    "    'talk.politics.guns',  # Politics\n",
    "    'soc.religion.christian' # Religion\n",
    "]\n",
    "\n",
    "# Load data\n",
    "print('Loading 20 Newsgroups dataset...')\n",
    "data = fetch_20newsgroups(\n",
    "    subset='all',\n",
    "    categories=CATEGORIES,\n",
    "    remove=('headers', 'footers', 'quotes'),  # Remove metadata for fair classification\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "texts = data.data\n",
    "labels = data.target\n",
    "label_names = data.target_names\n",
    "\n",
    "print(f'\\nDataset loaded: {len(texts)} documents, {len(label_names)} categories')\n",
    "print(f'\\nCategories:')\n",
    "for i, name in enumerate(label_names):\n",
    "    count = sum(1 for l in labels if l == i)\n",
    "    print(f'  {i}: {name} ({count} docs)')\n",
    "\n",
    "# Show a sample document\n",
    "print(f'\\n--- Sample Document (category: {label_names[labels[0]]}) ---')\n",
    "print(texts[0][:500] + '...' if len(texts[0]) > 500 else texts[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize class distribution\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Class counts\n",
    "unique, counts = np.unique(labels, return_counts=True)\n",
    "short_names = [n.split('.')[-1] for n in label_names]\n",
    "colors = ['#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6']\n",
    "axes[0].barh(short_names, counts, color=colors)\n",
    "axes[0].set_xlabel('Number of Documents')\n",
    "axes[0].set_title('Documents per Category')\n",
    "for i, c in enumerate(counts):\n",
    "    axes[0].text(c + 5, i, str(c), va='center', fontweight='bold')\n",
    "\n",
    "# Document length distribution\n",
    "lengths = [len(t.split()) for t in texts]\n",
    "axes[1].hist(lengths, bins=50, color='#0ea5e9', edgecolor='white', alpha=0.8)\n",
    "axes[1].set_xlabel('Document Length (words)')\n",
    "axes[1].set_ylabel('Count')\n",
    "axes[1].set_title(f'Document Length Distribution (mean={np.mean(lengths):.0f} words)')\n",
    "axes[1].axvline(np.mean(lengths), color='red', linestyle='--', label=f'Mean: {np.mean(lengths):.0f}')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 2: Preprocessing & Feature Engineering\n",
    "\n",
    "We use **TF-IDF** (Term Frequency-Inverse Document Frequency) to convert text into numerical features. This captures how important each word is to a document relative to the whole corpus."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Split data FIRST (before fitting vectorizer — prevents data leakage!)\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    texts, labels, test_size=0.2, random_state=42, stratify=labels\n",
    ")\n",
    "print(f'Train: {len(X_train)} docs | Test: {len(X_test)} docs')\n",
    "\n",
    "# TF-IDF Vectorization\n",
    "# WHY these parameters?\n",
    "# - max_features=10000: Keep top 10K words (balance between coverage and noise)\n",
    "# - ngram_range=(1,2): Include bigrams like 'neural network' (captures phrases)\n",
    "# - min_df=2: Ignore words appearing in fewer than 2 docs (removes typos)\n",
    "# - max_df=0.95: Ignore words in >95% of docs (removes stop words like 'the')\n",
    "# - sublinear_tf=True: Apply log scaling to term frequency (reduces impact of very frequent words)\n",
    "\n",
    "vectorizer = TfidfVectorizer(\n",
    "    max_features=10000,\n",
    "    ngram_range=(1, 2),\n",
    "    min_df=2,\n",
    "    max_df=0.95,\n",
    "    sublinear_tf=True\n",
    ")\n",
    "\n",
    "# Fit on training data ONLY, then transform both\n",
    "X_train_tfidf = vectorizer.fit_transform(X_train)\n",
    "X_test_tfidf = vectorizer.transform(X_test)\n",
    "\n",
    "print(f'\\nFeature matrix shape: {X_train_tfidf.shape}')\n",
    "print(f'Vocabulary size: {len(vectorizer.vocabulary_)} features')\n",
    "\n",
    "# Show top features per category\n",
    "print('\\nTop 5 TF-IDF features per category:')\n",
    "feature_names = vectorizer.get_feature_names_out()\n",
    "for cat_idx, cat_name in enumerate(label_names):\n",
    "    cat_mask = y_train == cat_idx\n",
    "    cat_tfidf = X_train_tfidf[cat_mask].mean(axis=0).A1\n",
    "    top_indices = cat_tfidf.argsort()[-5:][::-1]\n",
    "    top_words = [feature_names[i] for i in top_indices]\n",
    "    print(f'  {cat_name}: {top_words}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 3: Model Training — Baseline + Advanced\n",
    "\n",
    "We train 4 different models and compare them. This is how real ML projects work — you never just train one model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.naive_bayes import MultinomialNB\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.svm import LinearSVC\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "import time\n",
    "\n",
    "# Define models to compare\n",
    "models = {\n",
    "    'Naive Bayes (Baseline)': MultinomialNB(alpha=0.1),\n",
    "    'Logistic Regression': LogisticRegression(max_iter=1000, C=1.0, random_state=42),\n",
    "    'Linear SVM': LinearSVC(max_iter=2000, C=1.0, random_state=42),\n",
    "    'Random Forest': RandomForestClassifier(n_estimators=200, max_depth=50, random_state=42, n_jobs=-1),\n",
    "}\n",
    "\n",
    "results = {}\n",
    "print('Training and evaluating models...')\n",
    "print('=' * 60)\n",
    "\n",
    "for name, model in models.items():\n",
    "    start = time.time()\n",
    "    model.fit(X_train_tfidf, y_train)\n",
    "    train_time = time.time() - start\n",
    "    \n",
    "    y_pred = model.predict(X_test_tfidf)\n",
    "    acc = accuracy_score(y_test, y_pred)\n",
    "    \n",
    "    results[name] = {\n",
    "        'model': model,\n",
    "        'predictions': y_pred,\n",
    "        'accuracy': acc,\n",
    "        'train_time': train_time,\n",
    "    }\n",
    "    print(f'{name:30s} | Accuracy: {acc:.4f} | Time: {train_time:.2f}s')\n",
    "\n",
    "print('=' * 60)\n",
    "best_name = max(results, key=lambda k: results[k]['accuracy'])\n",
    "print(f'\\nBest model: {best_name} ({results[best_name][\"accuracy\"]:.4f})')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 4: Evaluation & Error Analysis\n",
    "\n",
    "Accuracy alone is not enough. We need to understand WHERE the model fails and WHY."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Detailed evaluation of the best model\n",
    "best = results[best_name]\n",
    "y_pred = best['predictions']\n",
    "\n",
    "print(f'Detailed Classification Report — {best_name}')\n",
    "print('=' * 70)\n",
    "print(classification_report(y_test, y_pred, target_names=label_names))\n",
    "\n",
    "# Confusion Matrix\n",
    "cm = confusion_matrix(y_test, y_pred)\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n",
    "            xticklabels=short_names, yticklabels=short_names, ax=ax)\n",
    "ax.set_xlabel('Predicted')\n",
    "ax.set_ylabel('Actual')\n",
    "ax.set_title(f'Confusion Matrix — {best_name}')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Error analysis: show misclassified examples\n",
    "print('\\n--- Misclassified Examples (first 3) ---')\n",
    "errors = np.where(y_pred != y_test)[0]\n",
    "for idx in errors[:3]:\n",
    "    print(f'\\nTrue: {label_names[y_test[idx]]} | Predicted: {label_names[y_pred[idx]]}')\n",
    "    print(f'Text: {X_test[idx][:200]}...')\n",
    "    print('-' * 50)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Model comparison visualization\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Accuracy comparison\n",
    "names = list(results.keys())\n",
    "accs = [results[n]['accuracy'] for n in names]\n",
    "times = [results[n]['train_time'] for n in names]\n",
    "bar_colors = ['#ef4444' if n == best_name else '#94a3b8' for n in names]\n",
    "\n",
    "axes[0].barh(names, accs, color=bar_colors)\n",
    "axes[0].set_xlabel('Accuracy')\n",
    "axes[0].set_title('Model Accuracy Comparison')\n",
    "axes[0].set_xlim(min(accs) - 0.05, 1.0)\n",
    "for i, a in enumerate(accs):\n",
    "    axes[0].text(a + 0.005, i, f'{a:.4f}', va='center', fontweight='bold')\n",
    "\n",
    "# Training time comparison\n",
    "axes[1].barh(names, times, color=bar_colors)\n",
    "axes[1].set_xlabel('Training Time (seconds)')\n",
    "axes[1].set_title('Training Time Comparison')\n",
    "for i, t in enumerate(times):\n",
    "    axes[1].text(t + 0.01, i, f'{t:.2f}s', va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print('\\nKey Takeaways:')\n",
    "print('  - Linear models (LR, SVM) often beat complex models on text data')\n",
    "print('  - Naive Bayes is a strong baseline — always start here')\n",
    "print('  - Random Forest is slower and often worse for high-dimensional sparse text')\n",
    "print('  - The best model balances accuracy AND training time')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 5: Make Predictions on New Text\n",
    "\n",
    "The whole point of a capstone is a working system. Let us classify new documents."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def classify_document(text, model_name=None):\n",
    "    \"\"\"Classify a new document using the best model.\"\"\"\n",
    "    name = model_name or best_name\n",
    "    model = results[name]['model']\n",
    "    features = vectorizer.transform([text])\n",
    "    prediction = model.predict(features)[0]\n",
    "    \n",
    "    # Get confidence if available\n",
    "    if hasattr(model, 'predict_proba'):\n",
    "        probs = model.predict_proba(features)[0]\n",
    "        confidence = probs[prediction]\n",
    "        print(f'Category: {label_names[prediction]}')\n",
    "        print(f'Confidence: {confidence:.1%}')\n",
    "        print('\\nAll probabilities:')\n",
    "        for i, (name_i, prob) in enumerate(zip(label_names, probs)):\n",
    "            bar = '#' * int(prob * 40)\n",
    "            print(f'  {name_i:30s} {prob:.3f} {bar}')\n",
    "    else:\n",
    "        print(f'Category: {label_names[prediction]}')\n",
    "    return label_names[prediction]\n",
    "\n",
    "# Test with new documents\n",
    "test_docs = [\n",
    "    'NASA launched a new satellite to study the atmosphere of Mars. The mission will take 7 months.',\n",
    "    'The Yankees won the World Series after a dramatic game 7 with a walk-off home run.',\n",
    "    'OpenGL rendering pipeline uses vertex shaders and fragment shaders for 3D graphics.',\n",
    "    'The second amendment debate continues as new legislation is proposed in Congress.',\n",
    "    'The church organized a community prayer service for Easter Sunday morning.',\n",
    "]\n",
    "\n",
    "print('=' * 70)\n",
    "print('CLASSIFYING NEW DOCUMENTS')\n",
    "print('=' * 70)\n",
    "for doc in test_docs:\n",
    "    print(f'\\nInput: \"{doc[:80]}...\"')\n",
    "    classify_document(doc)\n",
    "    print('-' * 50)"
   ]
