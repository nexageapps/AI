    "import numpy as np\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers\n",
    "\n",
    "# ============================================================================\n",
    "# CAPSTONE 4: Mini Code Generator — Character-Level Transformer\n",
    "# This gives you a working text generation baseline using B11-B13 concepts.\n",
    "# ============================================================================\n",
    "\n",
    "# Sample Python code corpus (replace with real code from GitHub)\n",
    "code_corpus = '''\n",
    "def hello():\n",
    "    print(\"hello world\")\n",
    "\n",
    "def add(a, b):\n",
    "    return a + b\n",
    "\n",
    "def multiply(x, y):\n",
    "    return x * y\n",
    "\n",
    "def factorial(n):\n",
    "    if n <= 1:\n",
    "        return 1\n",
    "    return n * factorial(n - 1)\n",
    "\n",
    "def fibonacci(n):\n",
    "    if n <= 1:\n",
    "        return n\n",
    "    return fibonacci(n-1) + fibonacci(n-2)\n",
    "\n",
    "def is_prime(n):\n",
    "    if n < 2:\n",
    "        return False\n",
    "    for i in range(2, n):\n",
    "        if n % i == 0:\n",
    "            return False\n",
    "    return True\n",
    "'''.strip()\n",
    "\n",
    "# Character-level tokenization (from B12 concepts)\n",
    "chars = sorted(set(code_corpus))\n",
    "char_to_idx = {c: i for i, c in enumerate(chars)}\n",
    "idx_to_char = {i: c for c, i in char_to_idx.items()}\n",
    "vocab_size = len(chars)\n",
    "\n",
    "print(f'Corpus: {len(code_corpus)} chars, {vocab_size} unique chars')\n",
    "print(f'Vocabulary: {chars}')\n",
    "\n",
    "# Create training sequences\n",
    "SEQ_LEN = 40\n",
    "encoded = [char_to_idx[c] for c in code_corpus]\n",
    "X, y = [], []\n",
    "for i in range(len(encoded) - SEQ_LEN):\n",
    "    X.append(encoded[i:i+SEQ_LEN])\n",
    "    y.append(encoded[i+SEQ_LEN])\n",
    "X = np.array(X)\n",
    "y = tf.keras.utils.to_categorical(y, vocab_size)\n",
    "print(f'Training sequences: {X.shape}')\n",
    "\n",
    "# Simple model (extend with Transformer from B11 for full project)\n",
    "model = tf.keras.Sequential([\n",
    "    layers.Embedding(vocab_size, 64, input_length=SEQ_LEN),\n",
    "    layers.LSTM(128, return_sequences=True),\n",
    "    layers.LSTM(128),\n",
    "    layers.Dense(vocab_size, activation='softmax')\n",
    "])\n",
    "model.compile(optimizer='adam', loss='categorical_crossentropy')\n",
    "model.fit(X, y, epochs=50, batch_size=32, verbose=0)\n",
    "print('Training complete!')\n",
    "\n",
    "# Generate code\n",
    "def generate_code(seed_text, length=200, temperature=0.5):\n",
    "    result = seed_text\n",
    "    for _ in range(length):\n",
    "        encoded_input = [char_to_idx.get(c, 0) for c in result[-SEQ_LEN:]]\n",
    "        encoded_input = np.array(encoded_input).reshape(1, -1)\n",
    "        preds = model.predict(encoded_input, verbose=0)[0]\n",
    "        preds = np.log(preds + 1e-8) / temperature\n",
    "        preds = np.exp(preds) / np.sum(np.exp(preds))\n",
    "        next_idx = np.random.choice(len(preds), p=preds)\n",
    "        result += idx_to_char[next_idx]\n",
    "    return result\n",
    "\n",
    "print('\\n--- Generated Code ---')\n",
    "print(generate_code('def ', length=150))\n",
    "print('\\nYour turn: Train on real Python code from GitHub, add a Transformer,')\n",
    "print('implement BPE tokenization, and build a code completion interface!')"
   ]
