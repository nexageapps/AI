    "# Compare unidirectional vs bidirectional\n",
    "def compare_directions():\n",
    "    \"\"\"Compare unidirectional and bidirectional RNNs\"\"\"\n",
    "    \n",
    "    # Unidirectional\n",
    "    uni_input = keras.Input(shape=(100,))\n",
    "    uni_x = layers.Embedding(10000, 128)(uni_input)\n",
    "    uni_x = layers.LSTM(64)(uni_x)\n",
    "    uni_model = Model(uni_input, uni_x)\n",
    "    \n",
    "    # Bidirectional\n",
    "    bi_input = keras.Input(shape=(100,))\n",
    "    bi_x = layers.Embedding(10000, 128)(bi_input)\n",
    "    bi_x = layers.Bidirectional(layers.LSTM(64))(bi_x)\n",
    "    bi_model = Model(bi_input, bi_x)\n",
    "    \n",
    "    print(\"Comparison:\")\n",
    "    print(\"=\" * 60)\n",
    "    print(f\"Unidirectional output shape: {uni_model.output_shape}\")\n",
    "    print(f\"Bidirectional output shape: {bi_model.output_shape}\")\n",
    "    print(f\"\\nUnidirectional params: {uni_model.count_params():,}\")\n",
    "    print(f\"Bidirectional params: {bi_model.count_params():,}\")\n",
    "    print(f\"\\nBidirectional has ~2x parameters (forward + backward)\")\n",
    "    print(\"=\" * 60)\n",
    "\n",
    "compare_directions()"
   ]
