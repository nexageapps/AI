   "source": [
    "# Practical comparison with synthetic data\n",
    "def benchmark_lstm_vs_gru():\n",
    "    \"\"\"Benchmark LSTM vs GRU on synthetic data\"\"\"\n",
    "    \n",
    "    # Generate synthetic sequence data\n",
    "    np.random.seed(42)\n",
    "    X = np.random.randint(0, 1000, size=(1000, 50))\n",
    "    y = np.random.randint(0, 2, size=(1000,))\n",
    "    \n",
    "    # LSTM model\n",
    "    lstm_model = keras.Sequential([\n",
    "        layers.Embedding(1000, 64, input_length=50),\n",
    "        layers.LSTM(32),\n",
    "        layers.Dense(1, activation='sigmoid')\n",
    "    ])\n",
    "    lstm_model.compile(optimizer='adam', loss='binary_crossentropy')\n",
    "    \n",
    "    # GRU model\n",
    "    gru_model = keras.Sequential([\n",
    "        layers.Embedding(1000, 64, input_length=50),\n",
    "        layers.GRU(32),\n",
    "        layers.Dense(1, activation='sigmoid')\n",
    "    ])\n",
    "    gru_model.compile(optimizer='adam', loss='binary_crossentropy')\n",
    "    \n",
    "    # Time training\n",
    "    import time\n",
    "    \n",
    "    start = time.time()\n",
    "    lstm_model.fit(X, y, epochs=3, batch_size=32, verbose=0)\n",
    "    lstm_time = time.time() - start\n",
    "    \n",
    "    start = time.time()\n",
    "    gru_model.fit(X, y, epochs=3, batch_size=32, verbose=0)\n",
    "    gru_time = time.time() - start\n",
    "    \n",
    "    print(\"Training Time Comparison:\")\n",
    "    print(\"=\" * 60)\n",
    "    print(f\"LSTM: {lstm_time:.2f} seconds\")\n",
    "    print(f\"GRU: {gru_time:.2f} seconds\")\n",
    "    print(f\"\\nGRU is {(lstm_time/gru_time - 1)*100:.1f}% faster\")\n",
    "    print(\"=\" * 60)\n",
    "\n",
    "benchmark_lstm_vs_gru()"
   ]
